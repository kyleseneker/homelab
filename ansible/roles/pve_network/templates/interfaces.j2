auto lo
iface lo inet loopback

auto {{ pve_network_physical_port }}
iface {{ pve_network_physical_port }} inet manual

auto {{ pve_network_bridge }}
iface {{ pve_network_bridge }} inet static
	address {{ pve_network_homelab_address }}
	gateway {{ pve_network_homelab_gateway }}
	bridge-ports {{ pve_network_physical_port }}
	bridge-stp off
	bridge-fd 0

auto {{ pve_network_bridge }}.{{ pve_network_management_vlan }}
iface {{ pve_network_bridge }}.{{ pve_network_management_vlan }} inet static
	address {{ pve_network_management_address }}
