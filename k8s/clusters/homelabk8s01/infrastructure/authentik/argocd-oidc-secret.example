# ArgoCD OIDC client secret for Authentik integration
# Get the client secret from Authentik admin UI after creating the
# OAuth2/OIDC Provider for ArgoCD (client ID: argocd)
#
# This secret is applied to the argocd namespace and merged into argocd-secret.
# Unlike other secrets, this one is applied via kustomize (not ArgoCD) since
# ArgoCD manages itself.
#
# Sealed Secrets workflow:
#   1. cp argocd-oidc-secret.example argocd-oidc-secret.yml
#   2. Edit argocd-oidc-secret.yml with the real client secret
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/infrastructure/authentik/argocd-oidc-secret.yml
#   4. Commit the generated argocd-oidc-sealed-secret.yml
#   5. rm argocd-oidc-secret.yml
#
# After sealing, manually apply: kubectl apply -f argocd-oidc-sealed-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: argocd-secret
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: argocd
type: Opaque
stringData:
  oidc.authentik.clientSecret: your_argocd_oidc_client_secret
