# Authentik credentials
# Sealed Secrets workflow:
#   1. cp authentik-secret.example authentik-secret.yml
#   2. Edit authentik-secret.yml with real values
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/infrastructure/authentik/authentik-secret.yml
#   4. Commit the generated authentik-sealed-secret.yml
#   5. rm authentik-secret.yml
#
# Generate secret key: openssl rand 60 | base64 -w 0
apiVersion: v1
kind: Secret
metadata:
  name: authentik-credentials
  namespace: auth
type: Opaque
stringData:
  AUTHENTIK_SECRET_KEY: your_50_plus_char_secret_key
  AUTHENTIK_BOOTSTRAP_PASSWORD: your_akadmin_password
  AUTHENTIK_BOOTSTRAP_TOKEN: your_bootstrap_api_token
  postgresql-password: your_postgresql_password
