# Slack webhook URL for Alertmanager notifications
# Get the webhook URL from your Slack workspace:
#   1. Go to https://api.slack.com/apps
#   2. Create a new app (or use existing) -> Incoming Webhooks
#   3. Add a webhook to #alerts channel
#   4. Copy the webhook URL
#
# Sealed Secrets workflow:
#   1. cp alertmanager-slack-secret.example alertmanager-slack-secret.yml
#   2. Edit alertmanager-slack-secret.yml with the real webhook URL
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/infrastructure/kube-prometheus-stack/alertmanager-slack-secret.yml
#   4. Commit the generated alertmanager-slack-sealed-secret.yml
#   5. rm alertmanager-slack-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-slack-webhook
  namespace: monitoring
type: Opaque
stringData:
  url: https://hooks.slack.com/services/T.../B.../xxx
