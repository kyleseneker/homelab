# Grafana OIDC client secret for Authentik integration
# Get the client secret from Authentik admin UI after creating the
# OAuth2/OIDC Provider for Grafana (client ID: grafana)
#
# Sealed Secrets workflow:
#   1. cp grafana-oidc-secret.example grafana-oidc-secret.yml
#   2. Edit grafana-oidc-secret.yml with the real client secret
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/infrastructure/kube-prometheus-stack/grafana-oidc-secret.yml
#   4. Commit the generated grafana-oidc-sealed-secret.yml
#   5. rm grafana-oidc-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: grafana-oidc-secret
  namespace: monitoring
type: Opaque
stringData:
  GRAFANA_OIDC_CLIENT_SECRET: your_grafana_oidc_client_secret
