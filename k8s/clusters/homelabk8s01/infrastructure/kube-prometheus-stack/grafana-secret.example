# Grafana admin credentials
#
# Sealed Secrets workflow:
#   1. cp grafana-secret.example grafana-secret.yml
#   2. Edit grafana-secret.yml with a real password
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/infrastructure/kube-prometheus-stack/grafana-secret.yml
#   4. Commit the generated grafana-sealed-secret.yml
#   5. rm grafana-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: grafana-admin
  namespace: monitoring
type: Opaque
stringData:
  admin-user: admin
  admin-password: your_grafana_password
