# MinIO root credentials for Velero backup storage
#
# Sealed Secrets workflow:
#   1. cp minio-secret.example minio-secret.yml
#   2. Edit minio-secret.yml with desired credentials
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/infrastructure/minio/minio-secret.yml
#   4. Commit the generated minio-sealed-secret.yml
#   5. rm minio-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: minio-credentials
  namespace: backups
type: Opaque
stringData:
  rootUser: minioadmin
  rootPassword: your_minio_password
