# Velero cloud credentials for MinIO S3 backend
# Uses the same rootUser/rootPassword from your MinIO secret
#
# Sealed Secrets workflow:
#   1. cp velero-secret.example velero-secret.yml
#   2. Edit velero-secret.yml with your MinIO credentials
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/infrastructure/velero/velero-secret.yml
#   4. Commit the generated velero-sealed-secret.yml
#   5. rm velero-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: velero-cloud-credentials
  namespace: backups
type: Opaque
stringData:
  cloud: |
    [default]
    aws_access_key_id = minioadmin
    aws_secret_access_key = your_minio_password
