# VPN credentials for Gluetun (PIA)
#
# Sealed Secrets workflow:
#   1. cp vpn-secret.example vpn-secret.yml
#   2. Edit vpn-secret.yml with real credentials
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/apps/arr/vpn-secret.yml
#   4. Commit the generated vpn-sealed-secret.yml
#   5. rm vpn-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: vpn-credentials
  namespace: arr
type: Opaque
stringData:
  OPENVPN_USER: your_pia_username
  OPENVPN_PASSWORD: your_pia_password
