# DO NOT commit this file with real credentials.
# Copy to vpn-secret.yml and apply manually:
#   cp vpn-secret.example vpn-secret.yml
#   # Edit vpn-secret.yml with real credentials
#   kubectl apply -f vpn-secret.yml
#
# Or use external-secrets-operator for automated secret management.
apiVersion: v1
kind: Secret
metadata:
  name: vpn-credentials
  namespace: arr
type: Opaque
stringData:
  username: your_pia_username
  password: your_pia_password
