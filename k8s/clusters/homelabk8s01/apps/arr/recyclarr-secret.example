# Recyclarr API keys for Sonarr/Radarr
# Get API keys from each app's Settings > General > API Key
#
# Sealed Secrets workflow:
#   1. cp recyclarr-secret.example recyclarr-secret.yml
#   2. Edit recyclarr-secret.yml with real API keys
#   3. make k8s-seal FILE=k8s/clusters/homelabk8s01/apps/arr/recyclarr-secret.yml
#   4. Commit the generated recyclarr-sealed-secret.yml
#   5. rm recyclarr-secret.yml
apiVersion: v1
kind: Secret
metadata:
  name: recyclarr-secrets
  namespace: arr
type: Opaque
stringData:
  secrets.yml: |
    sonarr_api_key: your_sonarr_api_key
    radarr_api_key: your_radarr_api_key
