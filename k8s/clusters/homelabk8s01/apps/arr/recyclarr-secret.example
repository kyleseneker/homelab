# DO NOT commit this file with real API keys.
# Copy to recyclarr-secret.yml and apply manually:
#   cp recyclarr-secret.example recyclarr-secret.yml
#   # Edit recyclarr-secret.yml with real API keys
#   kubectl apply -f recyclarr-secret.yml
#
# Get API keys from Sonarr/Radarr:
#   Settings > General > API Key
apiVersion: v1
kind: Secret
metadata:
  name: recyclarr-secrets
  namespace: arr
type: Opaque
stringData:
  secrets.yml: |
    sonarr_api_key: your_sonarr_api_key
    radarr_api_key: your_radarr_api_key
