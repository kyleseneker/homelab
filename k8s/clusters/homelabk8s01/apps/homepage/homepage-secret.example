# Homepage dashboard API keys
# Copy to homepage-secret.yml, fill in values, and apply:
#   cp homepage-secret.example homepage-secret.yml
#   # Edit homepage-secret.yml with real API keys
#   kubectl apply -f homepage-secret.yml
#
# Get API keys from each app's Settings > General page
apiVersion: v1
kind: Secret
metadata:
  name: homepage-secrets
  namespace: arr
type: Opaque
stringData:
  HOMEPAGE_VAR_JELLYFIN_KEY: your_jellyfin_api_key
  HOMEPAGE_VAR_JELLYSEERR_KEY: your_jellyseerr_api_key
  HOMEPAGE_VAR_SONARR_KEY: your_sonarr_api_key
  HOMEPAGE_VAR_RADARR_KEY: your_radarr_api_key
  HOMEPAGE_VAR_PROWLARR_KEY: your_prowlarr_api_key
  HOMEPAGE_VAR_BAZARR_KEY: your_bazarr_api_key
  HOMEPAGE_VAR_QBIT_PASSWORD: your_qbittorrent_password
