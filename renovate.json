{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 9am on saturday"
  ],
  "labels": [
    "renovate"
  ],
  "argocd": {
    "managerFilePatterns": [
      "/k8s/.+\\.yml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Container images in bjw-s app-template (repository + tag)",
      "managerFilePatterns": [
        "/k8s/.+\\.yml$/"
      ],
      "matchStrings": [
        "repository:\\s+(?<depName>\\S+)\\n\\s+tag:\\s+(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Inline container image references (image: name:tag)",
      "managerFilePatterns": [
        "/k8s/.+\\.yml$/"
      ],
      "matchStrings": [
        "image: (?<depName>[^:\\s]+):(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "ArgoCD install manifest version",
      "managerFilePatterns": [
        "/k8s/bootstrap/.+\\.yml$/"
      ],
      "matchStrings": [
        "https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/manifests/"
      ],
      "datasourceTemplate": "github-releases"
    }
  ],
  "pinDigests": true,
  "packageRules": [
    {
      "description": "Group app-template chart updates",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "app-template"
      ],
      "groupName": "app-template chart"
    },
    {
      "description": "Group linuxserver container images",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/^lscr\\.io\\/linuxserver\\//"
      ],
      "groupName": "linuxserver images"
    },
    {
      "description": "Group Grafana stack charts",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "loki",
        "alloy"
      ],
      "groupName": "grafana stack"
    },
    {
      "description": "Group Intel GPU charts",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "intel-device-plugins-gpu",
        "intel-device-plugins-operator"
      ],
      "groupName": "intel gpu"
    },
    {
      "description": "Ignore linuxserver Ubuntu base image tags for qbittorrent",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "allowedVersions": "/^[0-9]+\\.[0-9]+\\.[0-9]+$/"
    },
    {
      "description": "Group OpenClaw container images",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^ghcr\\.io\\/openclaw\\//"],
      "groupName": "openclaw"
    }
  ]
}
